# Database
DATABASE_URL=postgresql://user:password@localhost:5432/digitpenhub

# JWT
JWT_SECRET=your-secret-key-here
JWT_EXPIRES_IN=7d

# Server
PORT=5000
NODE_ENV=development

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ============================================================================
# PAYMENT GATEWAYS
# ============================================================================

# Flutterwave Payment Gateway (PRIMARY - RECOMMENDED FOR AFRICAN MARKETS)
FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-your-public-key
FLUTTERWAVE_SECRET_KEY=FLWSECK-your-secret-key
FLUTTERWAVE_ENCRYPTION_KEY=FLWSECK_TEST-your-encryption-key
FLUTTERWAVE_WEBHOOK_SECRET=your-webhook-secret-hash

# Paystack Payment Gateway (AFRICAN MARKETS - Optional)
# PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
# PAYSTACK_SECRET_KEY=sk_test_your_paystack_secret_key

# Stripe Payment Gateway (INTERNATIONAL - Optional)
# STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
# STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# PayPal Payment Gateway (INTERNATIONAL - Optional)
# PAYPAL_CLIENT_ID=your_paypal_client_id
# PAYPAL_SECRET=your_paypal_secret
# PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com

# ============================================================================
# OTHER SERVICES
# ============================================================================

# Email (for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# File Upload
MAX_FILE_SIZE=10485760
UPLOAD_DIR=./uploads

# Session
SESSION_SECRET=your-session-secret

# Sentry (Error Tracking)
SENTRY_DSN=your-sentry-dsn

# Redis (Optional - for caching)
REDIS_URL=redis://localhost:6379
