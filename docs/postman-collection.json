        {
          "name": "Create Deal",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('deal_id', response.data.id);",
                  "    pm.test('Deal created successfully', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data).to.have.property('id');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Enterprise Software Deal\",\n  \"amount\": 50000,\n  \"currency\": \"USD\",\n  \"pipeline_id\": \"{{pipeline_id}}\",\n  \"stage_id\": \"{{stage_id}}\",\n  \"company_id\": \"{{company_id}}\",\n  \"expected_close_date\": \"2026-12-31\",\n  \"tags\": [\"enterprise\", \"software\"],\n  \"custom_fields\": {\n    \"source\": \"website\",\n    \"priority\": \"high\"\n  }\n}"
            },
            "url": {
              "raw": "{{base_url}}/crm/deals",
              "host": ["{{base_url}}"],
              "path": ["crm", "deals"]
            },
            "description": "Create a new deal with all required and optional fields"
