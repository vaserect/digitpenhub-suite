                "exec": [
                  "if (pm.response.code === 201) {",
                  "    const response = pm.response.json();",
                  "    pm.collectionVariables.set('pipeline_id', response.data.id);",
                  "    if (response.data.stages && response.data.stages.length > 0) {",
                  "        pm.collectionVariables.set('stage_id', response.data.stages[0].id);",
                  "    }",
                  "    pm.test('Pipeline created with stages', () => {",
                  "        pm.expect(response.success).to.be.true;",
                  "        pm.expect(response.data.stages).to.have.lengthOf(6);",
                  "    });",
