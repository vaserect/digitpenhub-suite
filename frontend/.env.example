# API URL
NEXT_PUBLIC_API_URL=http://localhost:5000

# ============================================================================
# PAYMENT GATEWAYS
# ============================================================================

# Flutterwave (PRIMARY - RECOMMENDED FOR AFRICAN MARKETS)
NEXT_PUBLIC_FLUTTERWAVE_PUBLIC_KEY=FLWPUBK-your-public-key

# Paystack (AFRICAN MARKETS - Optional)
# NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your_paystack_public_key
# NEXT_PUBLIC_ENABLE_PAYSTACK=false

# Stripe (INTERNATIONAL - Optional)
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
# NEXT_PUBLIC_ENABLE_STRIPE=false

# PayPal (INTERNATIONAL - Optional)
# NEXT_PUBLIC_PAYPAL_CLIENT_ID=your_paypal_client_id
# NEXT_PUBLIC_ENABLE_PAYPAL=false

# ============================================================================
# APP CONFIGURATION
# ============================================================================

# App URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Feature Flags
NEXT_PUBLIC_ENABLE_MARKETPLACE=true
NEXT_PUBLIC_ENABLE_PAYMENTS=true